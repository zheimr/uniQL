{
  "permissions": {
    "allow": [
      "Bash(/home/zheimer/.cargo/bin/cargo *)",
      "Bash(/home/zheimer/.cargo/bin/cargo-llvm-cov *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(curl *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(sleep *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(python3 *)",
      "Read(/home/zheimer/uniQL/**)",
      "Edit(/home/zheimer/uniQL/**)",
      "Write(/home/zheimer/uniQL/**)",
      "Glob",
      "Grep",
      "WebSearch",
      "Agent(Explore)",
      "Agent(test-runner)",
      "Agent(code-reviewer)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Edit(/home/zheimer/Aetheris/**)",
      "Write(/home/zheimer/Aetheris/**)",
      "Edit(/etc/**)",
      "Edit(/root/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q '\\.rs$'; then /home/zheimer/.cargo/bin/rustfmt \"$FILE\" 2>/dev/null; fi; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/zheimer/uniQL && RESULT=$(/home/zheimer/.cargo/bin/cargo test --workspace 2>&1 | tail -5); if echo \"$RESULT\" | grep -q 'FAILED'; then echo \"TESTS FAILED! Fix before continuing.\" >&2; echo \"$RESULT\" >&2; exit 2; fi; echo \"All tests pass.\"; exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'UniQL Project Context: Rust workspace (uniql-core + uniql-engine + uniql-wasm). Cargo: /home/zheimer/.cargo/bin/cargo. Docker needs sudo (pw: zx9fzx9f). Engine at localhost:9090. 467 tests, 83% coverage. NEVER edit /home/zheimer/Aetheris/.'"
          }
        ]
      }
    ]
  }
}
